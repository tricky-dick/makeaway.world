---
const {
  title = "Makeaway",
  description = "A personal field guide for building a freer life.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <main>
      <header class="site-header">
        <a href="/" class="logo-link">
          <img
            class="site-logo"
            src="/circle logo.png"
            alt="Make a Way logo"
          />
        </a>

        <nav class="site-nav">
          <a href="/escape">Escape</a>
          <a href="/outside">Outside</a>
          <a href="/build">Build</a>
          <a href="/game">Game</a>
          <a href="/money">Money</a>
          <a href="/articles">Articles</a>
          <a href="/land">Land</a>
          <a href="/education">Education</a>
          <a href="/recipes/">Recipes</a>
          <a href="/garden/">Garden</a>
          <a href="https://www.reddit.com/r/Makeaway/">Community</a>
          <a href="/guides/">Guides</a>
        </nav>
      </header>

      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;

    --bg: #000000;
    --card: #0d0d0d;
    --card-hover: #141414;
    --card-border: rgba(245, 241, 232, 0.16);

    --text-main: #f5f1e8;
    --text-muted: #b8b2a6;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text-main);
  }

  main {
    width: min(1100px, calc(100% - 40px));
    margin: 0 auto;
    padding: 28px 0 96px;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    margin-bottom: 72px;
  }

  .logo-link {
    display: inline-flex;
    text-decoration: none;
  }

  .site-logo {
    width: 180px;
    height: auto;
    display: block;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 18px;
  }

  .site-nav a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .site-nav a:hover {
    color: var(--text-main);
  }

  h1 {
    max-width: 780px;
    margin: 0;
    font-size: clamp(3.2rem, 8vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  h2 {
    color: var(--text-main);
  }

  p {
    color: var(--text-muted);
    line-height: 1.6;
  }

  a {
    color: var(--text-main);
  }

  .intro {
    max-width: 680px;
    margin: 28px 0 0;
    color: var(--text-muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.6;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 18px;
    margin-top: 72px;
  }

  .card,
  .card:visited {
    display: block;
    min-height: 165px;
    padding: 24px;
    border: 1px solid var(--card-border);
    border-radius: 22px;
    background: var(--card);
    color: var(--text-main);
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: rgba(245, 241, 232, 0.45);
    background: var(--card-hover);
    box-shadow: 0 18px 45px rgba(255, 255, 255, 0.06);
  }

  .card:focus-visible {
    outline: 3px solid var(--text-main);
    outline-offset: 4px;
  }

  .card h2 {
    margin: 0 0 14px;
    color: var(--text-main);
    font-size: 1.25rem;
    line-height: 1.1;
  }

  .card p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
    font-size: 0.98rem;
  }

  .page-content {
    max-width: 760px;
  }

  @media (max-width: 800px) {
    main {
      width: min(100% - 28px, 1100px);
      padding: 20px 0 64px;
    }

    .site-header {
      align-items: flex-start;
      flex-direction: column;
      margin-bottom: 48px;
    }

    .site-logo {
      width: 140px;
    }

    .site-nav {
      justify-content: flex-start;
      gap: 14px;
    }

    h1 {
      font-size: clamp(2.8rem, 13vw, 4.5rem);
    }

    .cards {
      grid-template-columns: 1fr;
      margin-top: 52px;
    }
  }
</style>