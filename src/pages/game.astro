---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Runes of the Way">
  <main class="game-page">
    <section class="game-header">
      <p class="eyebrow">Make A Way Game</p>
      <h1>Runes of the Way</h1>
      <p>
        Escape The Grid before it resets. Collect all 5 runes, avoid the Wardens,
        and reach the Freedom Gate.
      </p>
    </section>

    <section class="game-layout">
      <div class="game-panel">
        <canvas id="gameCanvas" width="640" height="640"></canvas>
      </div>

      <aside class="story-panel">
        <h2>Story</h2>
        <p id="storyText">
          You wake inside The Grid. The walls are built from debt, fear,
          distraction, and routine. Somewhere in the dark, the runes are waiting.
        </p>

        <div class="stats-grid">
          <div>
            <span>Runes</span>
            <strong><span id="runeCount">0</span> / 5</strong>
          </div>

          <div>
            <span>Lives</span>
            <strong id="livesCount">3</strong>
          </div>

          <div>
            <span>Time</span>
            <strong id="timeCount">90</strong>
          </div>

          <div>
            <span>Score</span>
            <strong id="scoreCount">0</strong>
          </div>
        </div>

        <div class="status-box">
          <p><strong>Status:</strong> <span id="gameStatus">Find the runes</span></p>
          <p><strong>Rank:</strong> <span id="rankText">Unproven</span></p>
        </div>

        <div class="controls">
          <h3>Controls</h3>
          <p>Move with <strong>WASD</strong> or <strong>Arrow Keys</strong>.</p>
          <p>Collect hidden runes to reveal, endure, move faster, and break through walls.</p>
          <button id="restartButton" type="button">Restart Game</button>
        </div>
      </aside>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  // @ts-nocheck

  const canvas = document.getElementById("gameCanvas");

  if (!(canvas instanceof HTMLCanvasElement)) {
    throw new Error("Game canvas not found.");
  }

  const ctx = canvas.getContext("2d");

  if (!ctx) {
    throw new Error("Canvas context could not be created.");
  }

  function getElement(id) {
    const element = document.getElementById(id);

    if (!element) {
      throw new Error(`Missing element: ${id}`);
    }

    return element;
  }

  const storyText = getElement("storyText");
  const runeCount = getElement("runeCount");
  const livesCount = getElement("livesCount");
  const timeCount = getElement("timeCount");
  const scoreCount = getElement("scoreCount");
  const gameStatus = getElement("gameStatus");
  const rankText = getElement("rankText");
  const restartButton = getElement("restartButton");

  const tileSize = 40;
  const totalRunes = 5;
  const startingTime = 90;

  const originalMap = [
    "################",
    "#P.....#.......#",
    "#.###..#.###.#.#",
    "#...#..#...#.#.#",
    "###.#.###.#.#..#",
    "#...#.....#....#",
    "#.#####.#####..#",
    "#.....#.....#..#",
    "#.###.###.#.#.##",
    "#.#.....#.#....#",
    "#.#.###.#.####.#",
    "#...#...#......#",
    "###.#.#######..#",
    "#...#..........#",
    "#.....#.......G#",
    "################",
  ];

  const runeData = [
    {
      x: 5,
      y: 1,
      symbol: "ᚠ",
      name: "Wealth Rune",
      message:
        "You found the Wealth Rune. Debt weakens. The maze can no longer feed on your confusion.",
    },
    {
      x: 13,
      y: 1,
      symbol: "ᛒ",
      name: "Build Rune",
      message:
        "You found the Build Rune. Skills become tools. Tools become leverage. Leverage becomes a way out.",
    },
    {
      x: 1,
      y: 7,
      symbol: "ᚱ",
      name: "Road Rune",
      message:
        "You found the Road Rune. The default path cracks beneath your feet. You are no longer walking in circles.",
    },
    {
      x: 12,
      y: 13,
      symbol: "ᛟ",
      name: "Land Rune",
      message:
        "You found the Land Rune. Own your space. Build your base. Freedom needs somewhere to stand.",
    },
    {
      x: 3,
      y: 14,
      symbol: "ᛏ",
      name: "Freedom Rune",
      message:
        "You found the Freedom Rune. The gate hears you now. The way out is opening.",
    },
  ];

  const powerUpData = [
    {
      x: 9,
      y: 5,
      type: "clarity",
      symbol: "ᚲ",
      name: "Clarity Rune",
      message:
        "You found the Clarity Rune. The dark pulls back, and the maze reveals more of itself.",
    },
    {
      x: 5,
      y: 9,
      type: "guard",
      symbol: "ᛉ",
      name: "Guard Rune",
      message:
        "You found the Guard Rune. The next Warden that reaches you will break against it.",
    },
    {
      x: 13,
      y: 7,
      type: "momentum",
      symbol: "ᛇ",
      name: "Momentum Rune",
      message:
        "You found the Momentum Rune. For a short time, every step carries more weight.",
    },
    {
      x: 8,
      y: 11,
      type: "rupture",
      symbol: "ᚺ",
      name: "Rupture Rune",
      message:
        "You found the Rupture Rune. Walk into one wall to break it. Sometimes the path has to be made.",
    },
  ];

  const enemyStartData = [
    {
      x: 7,
      y: 7,
      name: "Debt Warden",
      message: "Debt caught you. The maze feeds on delay.",
    },
    {
      x: 10,
      y: 10,
      name: "Distraction Warden",
      message: "Distraction caught you. The path blurred for a moment.",
    },
  ];

  let map = [];
  let player = { x: 1, y: 1 };
  let runes = [];
  let powerUps = [];
  let enemies = [];
  let gate = { x: 14, y: 14 };
  let lives = 3;
  let timeLeft = startingTime;
  let score = 0;
  let gameWon = false;
  let gameLost = false;
  let guardActive = false;
  let ruptureActive = false;
  let momentumMoves = 0;
  let fogRadius = 6;
  let moveCount = 0;
  let timerInterval = null;
  let enemyMoveCounter = 0;

  function resetGame() {
    map = originalMap.map((row) => row.split(""));

    player = { x: 1, y: 1 };
    runes = runeData.map((rune) => ({ ...rune, collected: false }));
    powerUps = powerUpData.map((powerUp) => ({ ...powerUp, collected: false }));
    enemies = enemyStartData.map((enemy) => ({ ...enemy }));
    gate = { x: 14, y: 14 };

    lives = 3;
    timeLeft = startingTime;
    score = 0;
    gameWon = false;
    gameLost = false;
    guardActive = false;
    ruptureActive = false;
    momentumMoves = 0;
    fogRadius = 6;
    moveCount = 0;
    enemyMoveCounter = 0;

    storyText.textContent =
      "You wake inside The Grid. The walls are built from debt, fear, distraction, and routine. Somewhere in the dark, the runes are waiting.";

    gameStatus.textContent = "Find the runes";
    rankText.textContent = "Unproven";

    if (timerInterval) {
      clearInterval(timerInterval);
    }

    timerInterval = setInterval(tickTimer, 1000);

    updateStats();
    drawGame();
  }

  function tickTimer() {
    if (gameWon || gameLost) return;

    timeLeft -= 1;

    if (timeLeft <= 0) {
      timeLeft = 0;
      loseGame("The Grid reset before you escaped. The maze closes around you.");
    }

    updateStats();
  }

  function updateStats() {
    const collectedCount = runes.filter((rune) => rune.collected).length;

    runeCount.textContent = collectedCount.toString();
    livesCount.textContent = lives.toString();
    timeCount.textContent = timeLeft.toString();
    scoreCount.textContent = score.toString();

    if (score >= 900) {
      rankText.textContent = "Waymaker";
    } else if (score >= 600) {
      rankText.textContent = "Pathfinder";
    } else if (score >= 300) {
      rankText.textContent = "Awake";
    } else {
      rankText.textContent = "Unproven";
    }
  }

  function drawGame() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (let y = 0; y < map.length; y++) {
      for (let x = 0; x < map[y].length; x++) {
        if (map[y][x] === "#") {
          drawWall(x, y);
        } else {
          drawFloor(x, y);
        }

        if (!isVisible(x, y)) {
          drawFog(x, y);
        }
      }
    }

    drawRunes();
    drawPowerUps();
    drawGate();
    drawEnemies();
    drawPlayer();

    if (gameWon || gameLost) {
      drawEndOverlay();
    }
  }

  function isVisible(x, y) {
    const distance = Math.abs(player.x - x) + Math.abs(player.y - y);
    return distance <= fogRadius;
  }

  function drawFloor(x, y) {
    ctx.fillStyle = "#101510";
    ctx.fillRect(x * tileSize, y * tileSize, tileSize, tileSize);

    ctx.strokeStyle = "rgba(245, 241, 232, 0.04)";
    ctx.strokeRect(x * tileSize, y * tileSize, tileSize, tileSize);
  }

  function drawWall(x, y) {
    ctx.fillStyle = "#263326";
    ctx.fillRect(x * tileSize, y * tileSize, tileSize, tileSize);

    ctx.strokeStyle = "rgba(215, 181, 109, 0.16)";
    ctx.strokeRect(x * tileSize, y * tileSize, tileSize, tileSize);
  }

  function drawFog(x, y) {
    ctx.fillStyle = "rgba(0, 0, 0, 0.72)";
    ctx.fillRect(x * tileSize, y * tileSize, tileSize, tileSize);
  }

  function drawRunes() {
    runes.forEach((rune) => {
      if (rune.collected || !isVisible(rune.x, rune.y)) return;

      const centerX = rune.x * tileSize + tileSize / 2;
      const centerY = rune.y * tileSize + tileSize / 2;

      ctx.beginPath();
      ctx.arc(centerX, centerY, 16, 0, Math.PI * 2);
      ctx.fillStyle = "rgba(215, 181, 109, 0.24)";
      ctx.fill();

      ctx.beginPath();
      ctx.arc(centerX, centerY, 22, 0, Math.PI * 2);
      ctx.strokeStyle = "rgba(215, 181, 109, 0.28)";
      ctx.stroke();

      ctx.fillStyle = "#d7b56d";
      ctx.font = "28px serif";
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.fillText(rune.symbol, centerX, centerY + 1);
    });
  }

  function drawPowerUps() {
    powerUps.forEach((powerUp) => {
      if (powerUp.collected || !isVisible(powerUp.x, powerUp.y)) return;

      const centerX = powerUp.x * tileSize + tileSize / 2;
      const centerY = powerUp.y * tileSize + tileSize / 2;

      ctx.beginPath();
      ctx.arc(centerX, centerY, 15, 0, Math.PI * 2);
      ctx.fillStyle = "rgba(160, 190, 160, 0.16)";
      ctx.fill();

      ctx.beginPath();
      ctx.arc(centerX, centerY, 22, 0, Math.PI * 2);
      ctx.strokeStyle = "rgba(160, 190, 160, 0.24)";
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(centerX, centerY, 9, 0, Math.PI * 2);
      ctx.fillStyle = "rgba(215, 181, 109, 0.18)";
      ctx.fill();

      ctx.fillStyle = "#a8c7a1";
      ctx.font = "27px serif";
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.fillText(powerUp.symbol, centerX, centerY + 1);
    });
  }

  function drawGate() {
    if (!isVisible(gate.x, gate.y)) return;

    const allRunesCollected = runes.every((rune) => rune.collected);

    ctx.fillStyle = allRunesCollected ? "#d7b56d" : "#3b2f1f";
    ctx.fillRect(gate.x * tileSize + 6, gate.y * tileSize + 4, 28, 32);

    ctx.fillStyle = allRunesCollected ? "#101510" : "#d7b56d";
    ctx.font = "20px serif";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText("ᛉ", gate.x * tileSize + 20, gate.y * tileSize + 21);
  }

  function drawEnemies() {
    enemies.forEach((enemy) => {
      if (!isVisible(enemy.x, enemy.y)) return;

      const centerX = enemy.x * tileSize + tileSize / 2;
      const centerY = enemy.y * tileSize + tileSize / 2;

      ctx.beginPath();
      ctx.arc(centerX, centerY, 13, 0, Math.PI * 2);
      ctx.fillStyle = "#7b1e1e";
      ctx.fill();

      ctx.fillStyle = "#f5f1e8";
      ctx.font = "18px serif";
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.fillText("ᛜ", centerX, centerY + 1);
    });
  }

  function drawPlayer() {
    const centerX = player.x * tileSize + tileSize / 2;
    const centerY = player.y * tileSize + tileSize / 2;

    if (guardActive) {
      ctx.beginPath();
      ctx.arc(centerX, centerY, 18, 0, Math.PI * 2);
      ctx.strokeStyle = "rgba(168, 199, 161, 0.8)";
      ctx.lineWidth = 3;
      ctx.stroke();
      ctx.lineWidth = 1;
    }

    if (ruptureActive) {
      ctx.beginPath();
      ctx.arc(centerX, centerY, 21, 0, Math.PI * 2);
      ctx.strokeStyle = "rgba(215, 181, 109, 0.55)";
      ctx.lineWidth = 2;
      ctx.stroke();
      ctx.lineWidth = 1;
    }

    ctx.beginPath();
    ctx.arc(centerX, centerY, 12, 0, Math.PI * 2);
    ctx.fillStyle = "#f5f1e8";
    ctx.fill();

    ctx.beginPath();
    ctx.arc(centerX, centerY, 5, 0, Math.PI * 2);
    ctx.fillStyle = "#172117";
    ctx.fill();
  }

  function drawEndOverlay() {
    ctx.fillStyle = "rgba(0, 0, 0, 0.72)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.fillStyle = gameWon ? "#d7b56d" : "#f5f1e8";
    ctx.font = "bold 44px sans-serif";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(gameWon ? "YOU MADE A WAY" : "THE GRID WON", 320, 290);

    ctx.fillStyle = "#f5f1e8";
    ctx.font = "20px sans-serif";
    ctx.fillText(`Final Score: ${score}`, 320, 340);
    ctx.fillText("Press Restart Game to play again", 320, 380);
  }

  function canMoveTo(x, y) {
    if (y < 0 || y >= map.length) return false;
    if (x < 0 || x >= map[y].length) return false;
    return map[y][x] !== "#";
  }

  function movePlayer(dx, dy) {
    if (gameWon || gameLost) return;

    const nextX = player.x + dx;
    const nextY = player.y + dy;

    if (nextY < 0 || nextY >= map.length || nextX < 0 || nextX >= map[nextY].length) {
      return;
    }

    if (map[nextY][nextX] === "#") {
      if (ruptureActive) {
        map[nextY][nextX] = ".";
        ruptureActive = false;
        score += 50;
        storyText.textContent =
          "The Rupture Rune burns through the wall. Sometimes you do not find a path. You make one.";
        updateStats();
        drawGame();
      }

      return;
    }

    player.x = nextX;
    player.y = nextY;
    moveCount += 1;

    score += momentumMoves > 0 ? 8 : 3;

    if (momentumMoves > 0) {
      momentumMoves -= 1;
    }

    checkRuneCollection();
    checkPowerUpCollection();
    checkGate();
    checkEnemyCollision();

    enemyMoveCounter += 1;

    if (enemyMoveCounter >= 2) {
      enemyMoveCounter = 0;
      moveEnemies();
      checkEnemyCollision();
    }

    updateStats();
    drawGame();
  }

  function checkRuneCollection() {
    runes.forEach((rune) => {
      if (!rune.collected && rune.x === player.x && rune.y === player.y) {
        rune.collected = true;
        score += 150;
        storyText.textContent = rune.message;

        const collectedCount = runes.filter((r) => r.collected).length;

        if (collectedCount === totalRunes) {
          score += 250;
          gameStatus.textContent = "Freedom Gate unlocked";
          storyText.textContent =
            "The final rune burns in your hand. The gate ahead begins to open. For the first time, the path does not loop back.";
        }
      }
    });
  }

  function checkPowerUpCollection() {
    powerUps.forEach((powerUp) => {
      if (!powerUp.collected && powerUp.x === player.x && powerUp.y === player.y) {
        powerUp.collected = true;
        score += 75;
        storyText.textContent = powerUp.message;

        if (powerUp.type === "clarity") {
          fogRadius = 8;
          gameStatus.textContent = "Clarity Rune active";
        }

        if (powerUp.type === "guard") {
          guardActive = true;
          gameStatus.textContent = "Guard Rune active";
        }

        if (powerUp.type === "momentum") {
          momentumMoves = 12;
          gameStatus.textContent = "Momentum Rune active";
        }

        if (powerUp.type === "rupture") {
          ruptureActive = true;
          gameStatus.textContent = "Rupture Rune ready";
        }
      }
    });
  }

  function checkGate() {
    const allRunesCollected = runes.every((rune) => rune.collected);

    if (player.x === gate.x && player.y === gate.y) {
      if (allRunesCollected) {
        winGame();
      } else {
        storyText.textContent =
          "The Freedom Gate is sealed. The runes are still scattered through the maze.";
      }
    }
  }

  function moveEnemies() {
    enemies.forEach((enemy) => {
      const possibleMoves = [
        { dx: 0, dy: -1 },
        { dx: 0, dy: 1 },
        { dx: -1, dy: 0 },
        { dx: 1, dy: 0 },
      ];

      possibleMoves.sort(() => Math.random() - 0.5);

      let bestMove = null;
      let bestDistance = Infinity;

      possibleMoves.forEach((move) => {
        const nextX = enemy.x + move.dx;
        const nextY = enemy.y + move.dy;

        if (!canMoveTo(nextX, nextY)) return;

        const distance = Math.abs(player.x - nextX) + Math.abs(player.y - nextY);

        if (distance < bestDistance) {
          bestDistance = distance;
          bestMove = move;
        }
      });

      if (bestMove) {
        enemy.x += bestMove.dx;
        enemy.y += bestMove.dy;
      }
    });
  }

  function checkEnemyCollision() {
    enemies.forEach((enemy) => {
      if (enemy.x === player.x && enemy.y === player.y) {
        if (guardActive) {
          guardActive = false;
          score += 50;
          storyText.textContent =
            "The Guard Rune shatters and turns the Warden back. Keep moving.";
          resetPlayerPosition();
          return;
        }

        lives -= 1;
        score = Math.max(0, score - 100);
        storyText.textContent = enemy.message;

        if (lives <= 0) {
          loseGame("The Wardens dragged you back into the loop.");
        } else {
          resetPlayerPosition();
          gameStatus.textContent = "You were caught";
        }
      }
    });
  }

  function resetPlayerPosition() {
    player.x = 1;
    player.y = 1;
  }

  function winGame() {
    gameWon = true;

    if (timerInterval) {
      clearInterval(timerInterval);
    }

    score += timeLeft * 10;
    score += lives * 100;

    gameStatus.textContent = "You escaped";
    storyText.textContent =
      "You step through the Freedom Gate. Behind you, The Grid fades into darkness. Ahead of you is open land, open sky, and a road you choose for yourself. You made a way.";

    updateStats();
    drawGame();
  }

  function loseGame(message) {
    gameLost = true;

    if (timerInterval) {
      clearInterval(timerInterval);
    }

    gameStatus.textContent = "Game over";
    storyText.textContent = message;

    updateStats();
    drawGame();
  }

  document.addEventListener("keydown", (event) => {
    const key = event.key.toLowerCase();

    if (
      ["arrowup", "arrowdown", "arrowleft", "arrowright", "w", "a", "s", "d"].includes(
        key
      )
    ) {
      event.preventDefault();
    }

    if (key === "arrowup" || key === "w") {
      movePlayer(0, -1);
    }

    if (key === "arrowdown" || key === "s") {
      movePlayer(0, 1);
    }

    if (key === "arrowleft" || key === "a") {
      movePlayer(-1, 0);
    }

    if (key === "arrowright" || key === "d") {
      movePlayer(1, 0);
    }
  });

  restartButton.addEventListener("click", resetGame);

  resetGame();
</script>

<style>
  .game-page {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4rem 0;
  }

  .game-header {
    margin-bottom: 2rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: #d7b56d;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: #f5f1e8;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 1;
  }

  .game-header p {
    max-width: 760px;
    margin-top: 1rem;
    color: #d8d2c3;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .game-layout {
    display: grid;
    grid-template-columns: minmax(0, 560px) minmax(280px, 390px);
    gap: 1.5rem;
    align-items: start;
  }

  .game-panel,
  .story-panel {
    border: 1px solid rgba(245, 241, 232, 0.14);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.04);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
  }

  .game-panel {
    overflow: hidden;
    max-width: 560px;
  }

  canvas {
    display: block;
    width: 100%;
    height: auto;
    background: #020302;
  }

  .story-panel {
    padding: 1.5rem;
  }

  .story-panel h2,
  .story-panel h3 {
    margin: 0 0 0.75rem;
    color: #f5f1e8;
  }

  .story-panel p {
    color: #d8d2c3;
    line-height: 1.7;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .stats-grid div {
    padding: 0.85rem;
    border: 1px solid rgba(245, 241, 232, 0.12);
    border-radius: 0.85rem;
    background: rgba(0, 0, 0, 0.22);
  }

  .stats-grid span {
    display: block;
    color: #a9a291;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stats-grid strong {
    display: block;
    margin-top: 0.25rem;
    color: #d7b56d;
    font-size: 1.35rem;
  }

  .stats-grid strong span {
    display: inline;
    color: inherit;
    font-size: inherit;
    letter-spacing: normal;
    text-transform: none;
  }

  .status-box {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(245, 241, 232, 0.12);
  }

  .status-box p {
    margin: 0.5rem 0;
  }

  .controls {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(245, 241, 232, 0.12);
  }

  button {
    margin-top: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(215, 181, 109, 0.6);
    border-radius: 999px;
    background: rgba(215, 181, 109, 0.12);
    color: #f5f1e8;
    cursor: pointer;
    font: inherit;
  }

  button:hover {
    background: rgba(215, 181, 109, 0.22);
  }

