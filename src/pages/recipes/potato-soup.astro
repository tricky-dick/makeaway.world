---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Potato Soup">
  <main class="recipe-page">
    <section class="recipe-hero">
        <a class="back-link" href="/recipes/">← Back to recipes</a>
        
      <p class="eyebrow">Crock Pot Recipe</p>
      <h1>Potato Soup</h1>
      <p class="intro">
        A simple crock pot potato soup made with potatoes, broth, cream of chicken,
        and cream cheese. Easy, warm, and filling.
      </p>
    </section>

    <section class="recipe-card">
      <h2>Ingredients</h2>

      <ul class="ingredients-list">
        <li><span>32 oz</span> potatoes, fresh or frozen</li>
        <li><span>32 oz</span> chicken or vegetable broth</li>
        <li><span>1 can</span> cream of chicken soup</li>
        <li><span>1 block</span> cream cheese</li>
        <li><span>Optional</span> shredded cheese for topping</li>
      </ul>
    </section>

    <section class="recipe-card">
      <h2>Instructions</h2>

      <ol class="steps-list">
        <li>
          Add the potatoes to a large crock pot.
        </li>

        <li>
          Pour in the chicken or vegetable broth.
        </li>

        <li>
          Add the can of cream of chicken soup.
        </li>

        <li>
          Stir everything together until combined.
        </li>

        <li>
          Cover and cook on high for 4 hours.
        </li>

        <li>
          After 4 hours, add the block of cream cheese.
        </li>

        <li>
          Let the cream cheese melt into the soup.
        </li>

        <li>
          Stir until the soup is creamy and fully combined.
        </li>

        <li>
          Serve as is, or top with shredded cheese.
        </li>
      </ol>
    </section>

    <section class="recipe-note">
      <h2>Notes</h2>
      <p>
        This soup can be made with fresh or frozen potatoes. For a thicker soup,
        lightly mash some of the potatoes after the cream cheese has melted.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
    .back-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  margin-bottom: 2rem;
  color: #d7b56d;
  font-weight: 700;
  text-decoration: none;
}

.back-link:hover {
  color: #f5f1e8;
}
  .recipe-page {
    width: min(900px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4rem 0;
  }

  .recipe-hero {
    margin-bottom: 2rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: #d7b56d;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    line-height: 1;
  }

  .intro {
    max-width: 680px;
    margin-top: 1rem;
    color: #d8d2c3;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .recipe-card,
  .recipe-note {
    margin-top: 1.5rem;
    padding: 1.5rem;
    border: 1px solid rgba(245, 241, 232, 0.14);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.04);
  }

  h2 {
    margin: 0 0 1rem;
    font-size: 1.5rem;
  }

  .ingredients-list,
  .steps-list {
    margin: 0;
    padding-left: 1.25rem;
    color: #eee7d8;
    line-height: 1.8;
  }

  .ingredients-list li {
    margin-bottom: 0.35rem;
  }

  .ingredients-list span {
    display: inline-block;
    min-width: 80px;
    color: #d7b56d;
    font-weight: 700;
  }

  .steps-list li {
    margin-bottom: 0.75rem;
  }

  .recipe-note p {
    margin: 0;
    color: #d8d2c3;
    line-height: 1.7;
  }

  @media (max-width: 600px) {
    .recipe-page {
      padding: 2.5rem 0;
    }

    .recipe-card,
    .recipe-note {
      padding: 1.2rem;
    }
  }
</style>