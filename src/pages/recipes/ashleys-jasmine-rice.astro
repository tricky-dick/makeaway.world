---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Ashley's Jasmine Rice">
  <main class="recipe-page">
    <section class="recipe-hero">
        <a class="back-link" href="/recipes/">← Back to recipes</a>
      <p class="eyebrow">Rice Maker Recipe</p>
      <h1>Ashley's Jasmine Rice</h1>
      <p class="intro">
        A simple jasmine rice recipe made in an Aroma rice maker with rinsed rice
        and a little butter.
      </p>
    </section>

    <section class="recipe-card">
      <h2>Ingredients</h2>

      <ul class="ingredients-list">
        <li><span>1 cup</span> jasmine rice</li>
        <li><span>Water</span> for rinsing</li>
        <li><span>1 tbsp</span> butter</li>
      </ul>
    </section>

    <section class="recipe-card">
      <h2>Instructions</h2>

      <ol class="steps-list">
        <li>
          Add 1 cup of jasmine rice to a bowl or strainer.
        </li>

        <li>
          Rinse the rice with water until the water runoff is clear.
        </li>

        <li>
          Drain the rice well.
        </li>

        <li>
          Add the rinsed and drained rice to the Aroma rice maker.
        </li>

        <li>
          Add 1 tablespoon of butter.
        </li>

        <li>
          Close the rice maker lid.
        </li>

        <li>
          Press <strong>Power</strong>, then select <strong>White Rice</strong>.
        </li>

        <li>
          Let the rice cook. This usually takes about 40 minutes.
        </li>

        <li>
          Fluff the rice before serving.
        </li>
      </ol>
    </section>

    <section class="recipe-note">
      <h2>Notes</h2>
      <p>
        Rinsing the jasmine rice until the water runs clear helps remove extra starch
        and gives the rice a better texture.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
    .back-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  margin-bottom: 2rem;
  color: #d7b56d;
  font-weight: 700;
  text-decoration: none;
}

.back-link:hover {
  color: #f5f1e8;
}
  .recipe-page {
    width: min(900px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4rem 0;
  }

  .recipe-hero {
    margin-bottom: 2rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: #d7b56d;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    line-height: 1;
  }

  .intro {
    max-width: 680px;
    margin-top: 1rem;
    color: #d8d2c3;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .recipe-card,
  .recipe-note {
    margin-top: 1.5rem;
    padding: 1.5rem;
    border: 1px solid rgba(245, 241, 232, 0.14);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.04);
  }

  h2 {
    margin: 0 0 1rem;
    font-size: 1.5rem;
  }

  .ingredients-list,
  .steps-list {
    margin: 0;
    padding-left: 1.25rem;
    color: #eee7d8;
    line-height: 1.8;
  }

  .ingredients-list li {
    margin-bottom: 0.35rem;
  }

  .ingredients-list span {
    display: inline-block;
    min-width: 80px;
    color: #d7b56d;
    font-weight: 700;
  }

  .steps-list li {
    margin-bottom: 0.75rem;
  }

  .recipe-note p {
    margin: 0;
    color: #d8d2c3;
    line-height: 1.7;
  }

  @media (max-width: 600px) {
    .recipe-page {
      padding: 2.5rem 0;
    }

    .recipe-card,
    .recipe-note {
      padding: 1.2rem;
    }
  }
</style>