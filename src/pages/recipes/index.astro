---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Recipes | Makeaway"
  description="Simple recipes, camp cooking ideas, homestead meals, and practical food notes from Makeaway."
>
  <section class="page-content">
    
    <a class="back-link" href="/">← Back to home</a>

    <p class="eyebrow">Makeaway / Recipes</p>

    <h1>Recipes</h1>

    <p class="intro">
      Simple meals, camp cooking, homestead recipes, and practical food ideas
      for eating well without making life more complicated.
    </p>
  </section>

  <section class="recipe-grid">
    <a class="recipe-card" href="/recipes/pineapple-honey-bbq-beef-ribs/">
       <h2>Pineapple Honey BBQ Beef Ribs</h2>
      <p>
          Tender beef ribs marinated with pineapple and finished with a sticky honey
          BBQ glaze in the oven or on the grill.
       </p>
      </a>
    <a class="recipe-card" href="/recipes/potato-soup/">
      <h2>Potato Soup</h2>
      <p>A simple crock pot potato soup with potatoes, broth, cream of chicken, and cream cheese.</p>
    </a>
    <a class="recipe-card" href="/recipes/ashleys-jasmine-rice/">
      <h2>Ashley's Jasmine Rice</h2>
      <p>Simple jasmine rice made in an Aroma rice maker with rinsed rice and butter.</p>
    </a>
    <a class="recipe-card" href="/recipes/small-white-bread-loaf/">
      <h2>Small White Bread Loaf</h2>
      <p>A simple homemade white bread loaf made with flour, salt, yeast, and water.</p>
    </a>

  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--text-muted);
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-main);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .recipe-grid {
    display: grid;
    gap: 20px;
    margin-top: 72px;
  }

  .recipe-card,
  .recipe-card:visited {
    display: block;
    border: 1px solid var(--card-border);
    border-radius: 28px;
    padding: 34px;
    color: var(--text-main);
    text-decoration: none;
    background: var(--card);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .recipe-card:hover {
    transform: translateY(-6px);
    border-color: rgba(245, 241, 232, 0.45);
    background: var(--card-hover);
    box-shadow: 0 18px 45px rgba(255, 255, 255, 0.06);
  }

  .recipe-card span {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .recipe-card h2 {
    margin: 0;
    max-width: 760px;
    color: var(--text-main);
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .recipe-card p {
    max-width: 720px;
    margin: 20px 0 0;
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  @media (max-width: 760px) {
    .recipe-grid {
      margin-top: 52px;
    }

    .recipe-card,
    .recipe-card:visited {
      padding: 26px;
      border-radius: 24px;
    }

    .recipe-card h2 {
      font-size: clamp(2rem, 12vw, 3.3rem);
    }
  }
</style>