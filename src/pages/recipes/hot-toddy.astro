---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Hot Toddy">
  <main class="recipe-page">
    <section class="hero">
      <p class="eyebrow">Makeaway / Recipes</p>
      <h1>Hot Toddy</h1>
      <p class="intro">
        A warm, old-school home remedy made with honey, lemon, cinnamon, and a
        splash of whiskey or bourbon.
      </p>
    </section>

    <section class="recipe-card">
      <div class="recipe-content">
        <div class="recipe-label">Home Remedies</div>

        <h2>Hot Toddy</h2>

        <p class="recipe-note">
          This age-old remedy can help you settle in and warm up when you’re
          feeling under the weather. For a kid-friendly version, leave out the
          whiskey or bourbon and use extra lemon and honey instead.
        </p>

        <div class="meta-grid">
          <div>
            <span>Servings</span>
            <strong>1</strong>
          </div>
          <div>
            <span>Prep Time</span>
            <strong>5 min</strong>
          </div>
          <div>
            <span>Best For</span>
            <strong>Cold nights</strong>
          </div>
        </div>

        <div class="recipe-section">
          <h3>Ingredients</h3>

          <ul class="ingredient-list">
            <li><span>⅔ cup</span> boiling water</li>
            <li><span>2 teaspoons</span> honey</li>
            <li><span>2 tablespoons</span> whiskey or bourbon</li>
            <li><span>1</span> lemon slice</li>
            <li><span>1</span> cinnamon stick</li>
            <li><span>Ground nutmeg</span> for topping, optional</li>
          </ul>
        </div>

        <div class="recipe-section">
          <h3>Directions</h3>

          <ol class="step-list">
            <li>
              In a mug, combine the boiling water and honey. Stir until the honey
              is fully dissolved.
            </li>
            <li>
              Add the whiskey or bourbon, lemon slice, and cinnamon stick.
            </li>
            <li>
              Let it sit for 2 to 3 minutes so the lemon and cinnamon can steep.
            </li>
            <li>
              Remove the lemon and cinnamon stick.
            </li>
            <li>
              Sprinkle with nutmeg, if using, and serve warm.
            </li>
          </ol>
        </div>

        <div class="recipe-warning">
          <strong>Note:</strong>
          This is a comfort drink, not medical advice. Do not serve alcohol to
          children. For kids, skip the whiskey or bourbon completely.
        </div>
      </div>

      <aside class="recipe-side">
        <div class="image-card">
          <img
            src="/public/Hot-Toddy.jpg"
            alt="Two mugs of hot toddy with lemon and cinnamon"
            loading="lazy"
          />
        </div>

        <div class="quick-card">
          <h3>Kid-Friendly Swap</h3>
          <p>
            Leave out the whiskey or bourbon. Use warm water, honey, lemon, and
            cinnamon only.
          </p>
        </div>
      </aside>
    </section>
  </main>

  <style>
    .recipe-page {
      width: min(1100px, calc(100% - 48px));
      margin: 0 auto;
      padding: 3rem 0 5rem;
    }

    .hero {
      margin-bottom: 3rem;
    }

    .eyebrow,
    .recipe-label {
      color: #e4b860;
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .eyebrow {
      margin: 0 0 1rem;
    }

    h1,
    h2,
    h3,
    p {
      margin-top: 0;
    }

    h1 {
      margin-bottom: 1.25rem;
      color: #f5f1e8;
      font-size: clamp(4rem, 12vw, 7rem);
      line-height: 0.88;
      letter-spacing: -0.08em;
    }

    .intro {
      max-width: 760px;
      color: #d8cfba;
      font-size: clamp(1.2rem, 3vw, 1.6rem);
      line-height: 1.45;
    }

    .recipe-card {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 1.5rem;
      align-items: start;
    }

    .recipe-content,
    .image-card,
    .quick-card {
      border: 1px solid rgba(228, 184, 96, 0.24);
      background:
        linear-gradient(180deg, rgba(18, 18, 15, 0.96), rgba(6, 7, 6, 0.98));
      box-shadow:
        0 24px 80px rgba(0, 0, 0, 0.45),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .recipe-content {
      border-radius: 28px;
      padding: clamp(1.4rem, 4vw, 2.25rem);
    }

    .recipe-label {
      margin-bottom: 1.1rem;
    }

    h2 {
      margin-bottom: 0.85rem;
      color: #f5f1e8;
      font-size: clamp(2.3rem, 7vw, 4.2rem);
      line-height: 0.95;
      letter-spacing: -0.07em;
    }

    .recipe-note {
      max-width: 720px;
      color: #d8cfba;
      font-size: 1.12rem;
      font-style: italic;
      line-height: 1.65;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.85rem;
      margin: 1.8rem 0;
    }

    .meta-grid div {
      border: 1px solid rgba(228, 184, 96, 0.2);
      border-radius: 18px;
      background: rgba(5, 6, 5, 0.72);
      padding: 1rem;
    }

    .meta-grid span,
    .ingredient-list span {
      display: block;
      color: #e4b860;
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .meta-grid strong {
      display: block;
      margin-top: 0.35rem;
      color: #f5f1e8;
      font-size: 1.05rem;
    }

    .recipe-section {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(228, 184, 96, 0.18);
    }

    h3 {
      margin-bottom: 1rem;
      color: #f5f1e8;
      font-size: clamp(1.35rem, 4vw, 2rem);
      letter-spacing: -0.04em;
    }

    .ingredient-list,
    .step-list {
      margin: 0;
      color: #d8cfba;
      line-height: 1.65;
    }

    .ingredient-list {
      display: grid;
      gap: 0.85rem;
      padding: 0;
      list-style: none;
    }

    .ingredient-list li {
      border: 1px solid rgba(228, 184, 96, 0.16);
      border-radius: 16px;
      background: rgba(5, 6, 5, 0.58);
      padding: 0.9rem 1rem;
    }

    .ingredient-list span {
      margin-bottom: 0.2rem;
      text-transform: none;
      letter-spacing: 0;
    }

    .step-list {
      padding-left: 1.3rem;
    }

    .step-list li {
      margin-bottom: 0.75rem;
      padding-left: 0.3rem;
    }

    .recipe-warning {
      margin-top: 2rem;
      border: 1px solid rgba(228, 184, 96, 0.24);
      border-radius: 18px;
      background: rgba(228, 184, 96, 0.08);
      color: #d8cfba;
      line-height: 1.6;
      padding: 1rem;
    }

    .recipe-warning strong {
      color: #e4b860;
    }

    .recipe-side {
      display: grid;
      gap: 1rem;
    }

    .image-card {
      overflow: hidden;
      border-radius: 28px;
    }

    .image-card img {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
    }

    .quick-card {
      border-radius: 24px;
      padding: 1.25rem;
    }

    .quick-card h3 {
      margin-bottom: 0.55rem;
      font-size: 1.25rem;
    }

    .quick-card p {
      margin: 0;
      color: #d8cfba;
      line-height: 1.55;
    }

    @media (max-width: 820px) {
      .recipe-page {
        width: min(100% - 28px, 1100px);
        padding: 2rem 0 4rem;
      }

      .recipe-card {
        grid-template-columns: 1fr;
      }

      .meta-grid {
        grid-template-columns: 1fr;
      }

      .image-card img {
        aspect-ratio: 16 / 10;
      }
    }
  </style>
</BaseLayout>