---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Build | Makeaway"
  description="Build notes from Makeaway — side projects, websites, tools, experiments, and learning by making things."
>
  <section class="page-content">
    <a class="back-link" href="/">← Back to home</a>

    <p class="eyebrow">Makeaway / Build</p>

    <h1>Build</h1>

    <p class="intro">
      Side projects, websites, experiments, useful tools, and notes from
      learning by actually making things.
    </p>
  </section>

  <section class="link-section">
    <h2>Build Ideas</h2>

    <div class="article-list">
      <div class="video-card">
        <iframe
          src="https://www.youtube.com/embed/BxVfsrjv7hw"
          title="Building a Chicken Coop"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>

        <div class="video-card-content">
          <span class="label">YouTube</span>

          <h3>Building a Chicken Coop</h3>

          <p>A video walkthrough for building a backyard chicken coop.</p>

          <a
            class="watch-button"
            href="https://www.youtube.com/watch?v=BxVfsrjv7hw"
            target="_blank"
            rel="noopener noreferrer"
          >
            Watch on YouTube
          </a>
        </div>
      </div>

      <a class="article-button" href="/build/building-a-chuck-box">
        Building a Chuck Box
      </a>

      <a class="article-button" href="/build/survivalist-shelters">
        Survivalist Shelters
      </a>

      <a class="article-button" href="/build/newsletter-signup">
        Build a Newsletter Signup Later
      </a>

      <a class="article-button" href="/build/digital-product-guide">
        Create a Small Digital Product or Guide
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--text-muted);
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-main);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .link-section {
    margin-top: 72px;
  }

  .link-section h2 {
    margin: 0 0 22px;
    color: var(--text-main);
    font-size: 1.6rem;
  }

  .article-list {
    display: grid;
    gap: 14px;
  }

  .article-button,
  .article-button:visited {
    display: block;
    border: 1px solid var(--card-border);
    border-radius: 18px;
    padding: 18px 20px;
    background: var(--card);
    color: var(--text-main);
    font-weight: 800;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .article-button:hover {
    transform: translateY(-4px);
    border-color: rgba(245, 241, 232, 0.45);
    background: var(--card-hover);
    box-shadow: 0 18px 45px rgba(255, 255, 255, 0.06);
  }

  .article-button:focus-visible {
    outline: 3px solid var(--text-main);
    outline-offset: 4px;
  }

  .video-card {
    overflow: hidden;
    border: 1px solid var(--card-border);
    border-radius: 24px;
    background: var(--card);
  }

  .video-card iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  .video-card-content {
    padding: 22px;
  }

  .label {
    display: inline-block;
    margin-bottom: 12px;
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .video-card-content h3 {
    margin: 0 0 10px;
    color: var(--text-main);
    font-size: 1.3rem;
  }

  .video-card-content p {
    margin: 0 0 18px;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .watch-button,
  .watch-button:visited {
    display: inline-block;
    border: 1px solid rgba(245, 241, 232, 0.45);
    border-radius: 999px;
    padding: 10px 16px;
    color: var(--bg);
    background: var(--text-main);
    font-weight: 800;
    text-decoration: none;
    transition:
      transform 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .watch-button:hover {
    transform: translateY(-2px);
    background: #ffffff;
    box-shadow: 0 12px 24px rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 800px) {
    .link-section {
      margin-top: 52px;
    }
  }
</style>