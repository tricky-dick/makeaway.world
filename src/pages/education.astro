---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Education | Makeaway"
  description="Useful learning resources, tools, guides, and websites for building skills, becoming more self-sufficient, and creating a freer life."
>
  <section class="page-content">
    <a class="back-link" href="/">← Back to home</a>

    <p class="eyebrow">Makeaway / Education</p>

    <h1>Education</h1>

    <p class="intro">
      A collection of useful resources for learning skills, understanding
      money, building things, using technology better, and becoming more
      capable over time.
    </p>
  </section>

  <section class="resource-grid">
   <a class="resource-card" href="/zodiac/">
  <p class="card-kicker">Old Knowledge</p>
  <h2>Zodiac and the Human Body</h2>
  <p>
    Explore an interactive zodiac-man chart and click each sign for traditional
    body associations and symbolism.
  </p>
  <span class="card-link">Open the chart →</span>
</a>
    <a
      class="resource-card"
      href="https://www.khanacademy.org/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>General Learning</span>
      <h2>Khan Academy</h2>
      <p>
        Free lessons on math, finance, economics, science, and other core
        topics.
      </p>
    </a>

    <a
      class="resource-card"
      href="https://www.coursera.org/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>Courses</span>
      <h2>Coursera</h2>
      <p>
        Online courses from universities and companies covering technology,
        business, data, and more.
      </p>
    </a>

    <a
      class="resource-card"
      href="https://www.edx.org/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>Courses</span>
      <h2>edX</h2>
      <p>
        University-style online courses for deeper learning in technical and
        professional subjects.
      </p>
    </a>

    <a
      class="resource-card"
      href="https://www.freecodecamp.org/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>Technology</span>
      <h2>freeCodeCamp</h2>
      <p>
        Free coding lessons and projects for learning web development,
        programming, and technical skills.
      </p>
    </a>

    <a
      class="resource-card"
      href="https://www.investopedia.com/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>Money</span>
      <h2>Investopedia</h2>
      <p>
        Clear explanations of investing, markets, retirement, options,
        dividends, and financial terms.
      </p>
    </a>

    <a
      class="resource-card"
      href="https://www.extension.org/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>Homestead</span>
      <h2>Extension Foundation</h2>
      <p>
        Educational resources connected to land-grant universities,
        agriculture, gardening, and rural knowledge.
      </p>
    </a>

    <a
      class="resource-card"
      href="https://www.almanac.com/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>Gardening</span>
      <h2>Old Farmer’s Almanac</h2>
      <p>
        Practical gardening, planting, weather, and seasonal living
        information.
      </p>
    </a>

    <a
      class="resource-card"
      href="https://www.inaturalist.org/"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span>Outside</span>
      <h2>iNaturalist</h2>
      <p>
        Learn to identify plants, animals, insects, and natural life around
        you.
      </p>
    </a>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--text-muted);
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-main);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-top: 72px;
  }

  .resource-card,
  .resource-card:visited {
    display: block;
    border: 1px solid var(--card-border);
    border-radius: 28px;
    padding: 28px;
    color: var(--text-main);
    text-decoration: none;
    background: var(--card);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .resource-card:hover {
    transform: translateY(-6px);
    border-color: rgba(245, 241, 232, 0.45);
    background: var(--card-hover);
    box-shadow: 0 18px 45px rgba(255, 255, 255, 0.06);
  }

  .resource-card span {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .resource-card h2 {
    margin: 0;
    color: var(--text-main);
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    overflow-wrap: anywhere;
    word-break: break-word;
    line-height: 1;
  }

  .resource-card p {
    margin: 18px 0 0;
    color: var(--text-muted);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  @media (max-width: 760px) {
    .resource-grid {
      grid-template-columns: 1fr;
      margin-top: 52px;
    }

    .resource-card,
    .resource-card:visited {
      padding: 24px;
      border-radius: 24px;
    }
  }
</style>