---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Money | Makeaway"
  description="Money notes from Makeaway — investing, dividends, options, retirement, taxes, and building more financial independence over time."
>
  <section class="page-content">
    <a class="back-link" href="/">← Back to home</a>

    <p class="eyebrow">Makeaway / Money</p>

    <h1>Money</h1>

    <p class="intro">
      Investing, dividends, options, retirement planning, taxes, and the long
      road toward more financial independence.
    </p>
  </section>

  <section class="link-section">
    <h2>Money Moves</h2>

    <div class="article-list">
      <a class="article-button" href="/money/401k-basics">
        401K basics
      </a>

      <a class="article-button" href="/money/trading-options">
        Trading options
      </a>

      <a class="article-button" href="/money/stock-picking">
        Stock picking
      </a>

      <a class="article-button" href="/money/health-care-and-tax-avoidance">
        Health care and tax avoidance
      </a>

      <a class="article-button" href="/money/does-anyone-even-care">
        Does anyone even care?
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--text-muted);
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-main);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .link-section {
    margin-top: 72px;
  }

  .link-section h2 {
    margin: 0 0 22px;
    color: var(--text-main);
    font-size: 1.6rem;
  }

  .article-list {
    display: grid;
    gap: 14px;
  }

  .article-button,
  .article-button:visited {
    display: block;
    border: 1px solid var(--card-border);
    border-radius: 18px;
    padding: 18px 20px;
    background: var(--card);
    color: var(--text-main);
    font-weight: 800;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .article-button:hover {
    transform: translateY(-4px);
    border-color: rgba(245, 241, 232, 0.45);
    background: var(--card-hover);
    box-shadow: 0 18px 45px rgba(255, 255, 255, 0.06);
  }

  .article-button:focus-visible {
    outline: 3px solid var(--text-main);
    outline-offset: 4px;
  }

  @media (max-width: 800px) {
    .link-section {
      margin-top: 52px;
    }
  }
</style>