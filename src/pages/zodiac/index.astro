---
import BaseLayout from "../../layouts/BaseLayout.astro";

const signs = [
  {
    name: "Aries",
    slug: "aries",
    body: "Head",
    className: "aries",
  },
  {
    name: "Taurus",
    slug: "taurus",
    body: "Neck & Throat",
    className: "taurus",
  },
  {
    name: "Gemini",
    slug: "gemini",
    body: "Lungs",
    className: "gemini",
  },
  {
    name: "Cancer",
    slug: "cancer",
    body: "Stomach",
    className: "cancer",
  },
  {
    name: "Leo",
    slug: "leo",
    body: "Heart",
    className: "leo",
  },
  {
    name: "Virgo",
    slug: "virgo",
    body: "Intestines",
    className: "virgo",
  },
  {
    name: "Libra",
    slug: "libra",
    body: "Kidneys",
    className: "libra",
  },
  {
    name: "Scorpio",
    slug: "scorpio",
    body: "Reproductive Organs",
    className: "scorpio",
  },
  {
    name: "Sagittarius",
    slug: "sagittarius",
    body: "Hips & Thighs",
    className: "sagittarius",
  },
  {
    name: "Capricorn",
    slug: "capricorn",
    body: "Bones & Joints",
    className: "capricorn",
  },
  {
    name: "Aquarius",
    slug: "aquarius",
    body: "Circulation",
    className: "aquarius",
  },
  {
    name: "Pisces",
    slug: "pisces",
    body: "Feet",
    className: "pisces",
  },
];
---

<BaseLayout title="Zodiac and the Human Body">
  <main class="zodiac-page">
    <section class="hero">
      <p class="eyebrow">Makeaway / Education / Old Knowledge</p>
      <h1>The Zodiac and the Human Body</h1>
      <p class="intro">
        An interactive old-world style chart connecting the zodiac signs with
        traditional body associations. Click a sign to explore more.
      </p>
    </section>

    <section class="chart-card">
      <div class="chart-wrap">
        <img
          src="/zodiac-man.png"
          alt="The Zodiac and the Human Body chart"
          class="zodiac-chart"
        />

        {signs.map((sign) => (
          <a
            class={`zodiac-hotspot ${sign.className}`}
            href={`/zodiac/${sign.slug}/`}
            aria-label={`Open ${sign.name}, associated with ${sign.body}`}
          >
            <span>
              <strong>{sign.name}</strong>
              <small>{sign.body}</small>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="sign-grid">
      {signs.map((sign) => (
        <a class="sign-card" href={`/zodiac/${sign.slug}/`}>
          <p class="card-kicker">{sign.body}</p>
          <h2>{sign.name}</h2>
          <span>Explore sign →</span>
        </a>
      ))}
    </section>

    <section class="note-card">
      <h2>About This Chart</h2>
      <p>
        This page is inspired by historic zodiac-man diagrams, which connected
        astrology, seasons, anatomy, and symbolic medicine. Treat it as cultural,
        historical, and symbolic material — not medical guidance.
      </p>
    </section>
  </main>

  <style>
    .zodiac-page {
      width: min(1180px, calc(100% - 48px));
      margin: 0 auto;
      padding: 3rem 0 5rem;
    }

    .hero {
      margin-bottom: 2.5rem;
    }

    .eyebrow,
    .card-kicker {
      margin: 0 0 1rem;
      color: #e4b860;
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    h1,
    h2,
    p {
      margin-top: 0;
    }

    h1 {
      max-width: 980px;
      margin-bottom: 1.25rem;
      color: #f5f1e8;
      font-size: clamp(3.2rem, 9vw, 7rem);
      line-height: 0.88;
      letter-spacing: -0.08em;
    }

    .intro {
      max-width: 780px;
      color: #d8cfba;
      font-size: clamp(1.15rem, 3vw, 1.55rem);
      line-height: 1.5;
    }

    .chart-card,
    .note-card,
    .sign-card {
      border: 1px solid rgba(228, 184, 96, 0.24);
      background:
        linear-gradient(180deg, rgba(18, 18, 15, 0.96), rgba(6, 7, 6, 0.98));
      box-shadow:
        0 24px 80px rgba(0, 0, 0, 0.45),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .chart-card {
      border-radius: 30px;
      padding: clamp(0.75rem, 2vw, 1.25rem);
      overflow: hidden;
    }

    .chart-wrap {
      position: relative;
      width: 100%;
      max-width: 980px;
      margin: 0 auto;
    }

    .zodiac-chart {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 24px;
    }

    .zodiac-hotspot {
      position: absolute;
      display: grid;
      place-items: center;
      width: 15%;
      height: 9%;
      border: 1px solid rgba(228, 184, 96, 0);
      border-radius: 999px;
      color: #f5f1e8;
      text-decoration: none;
      transform: translate(-50%, -50%);
      transition:
        background 180ms ease,
        border-color 180ms ease,
        box-shadow 180ms ease,
        transform 180ms ease;
    }

    .zodiac-hotspot span {
      display: none;
      min-width: 140px;
      border: 1px solid rgba(228, 184, 96, 0.35);
      border-radius: 16px;
      background: rgba(5, 6, 5, 0.92);
      padding: 0.7rem 0.8rem;
      text-align: center;
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.45);
    }

    .zodiac-hotspot strong,
    .zodiac-hotspot small {
      display: block;
    }

    .zodiac-hotspot strong {
      color: #e4b860;
      font-size: 0.95rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .zodiac-hotspot small {
      margin-top: 0.2rem;
      color: #d8cfba;
      font-size: 0.78rem;
    }

    .zodiac-hotspot:hover,
    .zodiac-hotspot:focus-visible {
      border-color: rgba(228, 184, 96, 0.55);
      background: rgba(228, 184, 96, 0.1);
      box-shadow: 0 0 28px rgba(228, 184, 96, 0.28);
      outline: none;
      transform: translate(-50%, -50%) scale(1.05);
    }

    .zodiac-hotspot:hover span,
    .zodiac-hotspot:focus-visible span {
      display: block;
    }

    .aries {
      left: 64%;
      top: 25%;
    }

    .taurus {
      left: 84%;
      top: 35%;
    }

    .gemini {
      left: 28%;
      top: 28%;
    }

    .cancer {
      left: 86%;
      top: 49%;
    }

    .leo {
      left: 82%;
      top: 64%;
    }

    .virgo {
      left: 76%;
      top: 76%;
    }

    .libra {
      left: 15%;
      top: 55%;
    }

    .scorpio {
      left: 63%;
      top: 84%;
    }

    .sagittarius {
      left: 18%;
      top: 70%;
    }

    .capricorn {
      left: 13%;
      top: 40%;
    }

    .aquarius {
      left: 28%;
      top: 83%;
    }

    .pisces {
      left: 48%;
      top: 89%;
    }

    .sign-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .sign-card {
      display: block;
      border-radius: 22px;
      color: #f5f1e8;
      padding: 1.2rem;
      text-decoration: none;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background 180ms ease;
    }

    .sign-card:hover {
      transform: translateY(-3px);
      border-color: rgba(228, 184, 96, 0.58);
      background:
        linear-gradient(180deg, rgba(26, 24, 18, 0.98), rgba(8, 8, 7, 0.98));
    }

    .sign-card h2 {
      margin-bottom: 0.8rem;
      font-size: clamp(1.5rem, 4vw, 2rem);
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .sign-card span {
      color: #e4b860;
      font-weight: 900;
    }

    .note-card {
      margin-top: 1.5rem;
      border-radius: 28px;
      padding: clamp(1.25rem, 3vw, 2rem);
    }

    .note-card h2 {
      margin-bottom: 0.75rem;
      color: #f5f1e8;
      font-size: clamp(2rem, 5vw, 3.2rem);
      line-height: 0.95;
      letter-spacing: -0.06em;
    }

    .note-card p {
      max-width: 820px;
      color: #d8cfba;
      line-height: 1.65;
    }

    @media (max-width: 820px) {
      .zodiac-page {
        width: min(100% - 28px, 1180px);
        padding: 2rem 0 4rem;
      }

      .sign-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .zodiac-hotspot {
        width: 18%;
        height: 8%;
      }

      .zodiac-hotspot span {
        min-width: 120px;
        padding: 0.55rem 0.65rem;
      }
    }

    @media (max-width: 520px) {
      .sign-grid {
        grid-template-columns: 1fr;
      }

      .chart-card {
        overflow-x: auto;
      }

      .chart-wrap {
        min-width: 620px;
      }
    }
  </style>
</BaseLayout>