---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Escape | Makeaway"
  description="Thoughts on work, burnout, freedom, and designing a life that feels more your own."
>
  <section class="page-content">
    <a class="back-link" href="/">← Back to home</a>

    <p class="eyebrow">Makeaway / Escape</p>

    <h1>Escape</h1>

    <p class="intro">
      Thoughts on work, burnout, freedom, and designing a life that feels more
      your own.
    </p>
  </section>

  <section class="escape-grid">
    <a class="escape-card" href="/articles/what-it-means-to-escape-the-rat-race">
      <span>Escape</span>

      <h2>What It Means to Escape the Rat Race</h2>

      <p>
        A breakdown of what the rat race really is, what it means to escape it,
        and how freedom is built through money, skills, land, and better use of
        technology.
      </p>
    </a>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--text-muted);
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-main);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .escape-grid {
    display: grid;
    gap: 20px;
    margin-top: 72px;
  }

  .escape-card,
  .escape-card:visited {
    display: block;
    border: 1px solid var(--card-border);
    border-radius: 28px;
    padding: 34px;
    color: var(--text-main);
    text-decoration: none;
    background: var(--card);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .escape-card:hover {
    transform: translateY(-6px);
    border-color: rgba(245, 241, 232, 0.45);
    background: var(--card-hover);
    box-shadow: 0 18px 45px rgba(255, 255, 255, 0.06);
  }

  .escape-card span {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .escape-card h2 {
    margin: 0;
    max-width: 760px;
    color: var(--text-main);
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .escape-card p {
    max-width: 720px;
    margin: 20px 0 0;
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  @media (max-width: 760px) {
    .escape-grid {
      margin-top: 52px;
    }

    .escape-card,
    .escape-card:visited {
      padding: 26px;
      border-radius: 24px;
    }

    .escape-card h2 {
      font-size: clamp(2rem, 12vw, 3.3rem);
    }
  }
</style>