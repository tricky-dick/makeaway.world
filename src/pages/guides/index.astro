---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Guides | Makeaway"
  description="Practical guides, reference material, training documents, and useful resources from Makeaway."
>
  <section class="page-content">
    <a class="back-link" href="/">← Back to home</a>

    <p class="eyebrow">Makeaway / Guides</p>

    <h1>Guides</h1>

    <p class="intro">
      Practical reference guides, training material, and useful resources for
      building skills, learning systems, and becoming more capable.
    </p>
  </section>

  <section class="guide-grid">
    <a class="guide-card" href="/guides/sere-training-guide/">
      <h2>SERE Training Guide</h2>
      <p>
        A public survival, evasion, resistance, and escape handbook covering
        mindset, shelter, firecraft, water, food, navigation, signaling, and
        recovery basics.
      </p>
    </a>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--text-muted);
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-main);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .guide-grid {
    display: grid;
    gap: 20px;
    margin-top: 72px;
  }

  .guide-card,
  .guide-card:visited {
    display: block;
    border: 1px solid var(--card-border);
    border-radius: 28px;
    padding: 34px;
    color: var(--text-main);
    text-decoration: none;
    background: var(--card);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .guide-card:hover {
    transform: translateY(-6px);
    border-color: rgba(245, 241, 232, 0.45);
    background: var(--card-hover);
    box-shadow: 0 18px 45px rgba(255, 255, 255, 0.06);
  }

  .guide-card h2 {
    margin: 0;
    max-width: 760px;
    color: var(--text-main);
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .guide-card p {
    max-width: 720px;
    margin: 20px 0 0;
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  @media (max-width: 760px) {
    .guide-grid {
      margin-top: 52px;
    }

    .guide-card,
    .guide-card:visited {
      padding: 26px;
      border-radius: 24px;
    }

    .guide-card h2 {
      font-size: clamp(2rem, 12vw, 3.3rem);
    }
  }
</style>