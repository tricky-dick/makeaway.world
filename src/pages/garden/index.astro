---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Garden | Makeaway"
  description="Garden notes, growing experiments, practical food growing, and homestead garden ideas from Makeaway."
>
  <section class="page-content">
    <a class="back-link" href="/">← Back to home</a>

    <p class="eyebrow">Makeaway / Garden</p>

    <h1>Garden</h1>

    <p class="intro">
      Practical garden notes, growing experiments, seed starting, soil work,
      harvest lessons, and simple ways to grow more of your own food.
    </p>
  </section>

  <section class="garden-grid">

    <a
  class="garden-card"
  href="https://growhoss.com/"
  target="_blank"
  rel="noopener noreferrer"
>
  <h2>Hoss</h2>
  <p>
    Garden seeds, tools, supplies, and growing resources from Hoss for building
    a more productive home garden.
  </p>
</a>


  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--text-muted);
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-main);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .garden-grid {
    display: grid;
    gap: 20px;
    margin-top: 72px;
  }

  .garden-card,
  .garden-card:visited {
    display: block;
    border: 1px solid var(--card-border);
    border-radius: 28px;
    padding: 34px;
    color: var(--text-main);
    text-decoration: none;
    background: var(--card);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .garden-card:hover {
    transform: translateY(-6px);
    border-color: rgba(245, 241, 232, 0.45);
    background: var(--card-hover);
    box-shadow: 0 18px 45px rgba(255, 255, 255, 0.06);
  }

  .garden-card span {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .garden-card h2 {
    margin: 0;
    max-width: 760px;
    color: var(--text-main);
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .garden-card p {
    max-width: 720px;
    margin: 20px 0 0;
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  @media (max-width: 760px) {
    .garden-grid {
      margin-top: 52px;
    }

    .garden-card,
    .garden-card:visited {
      padding: 26px;
      border-radius: 24px;
    }

    .garden-card h2 {
      font-size: clamp(2rem, 12vw, 3.3rem);
    }
  }
</style>