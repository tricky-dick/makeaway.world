---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Articles | Makeaway"
  description="Articles from Makeaway about escaping the rat race, building useful skills, land, self-sufficiency, money, and living a more intentional life."
>
  <section class="page-content">
    <a class="back-link" href="/">← Back to home</a>

    <p class="eyebrow">Makeaway</p>

    <h1>Articles</h1>

    <p class="intro">
      Notes, essays, research, and guides about using technology, land,
      practical skills, and money to build a freer, more human life.
    </p>
  </section>

  <section class="article-grid">
  
      <a class="article-card" href="/articles/baseline-financial-freedom/">
     <span>Money</span>
     <h2>Baseline Financial Freedom</h2>
     <p>
    Financial freedom does not start with being rich. It starts with building
    control, stability, and breathing room.
      </p>
      </a>
    <a class="article-card" href="/articles/what-it-means-to-escape-the-rat-race">
      <span>Mission</span>
      <h2>What it means to escape the rat race</h2>
      <p>
        Time to get off the wheel.
      </p>
    </a>

    <a class="article-card" href="/articles/why-im-starting-makeaway">
      <span>Mission</span>
      <h2>Why I’m Starting Makeaway</h2>
      <p>
        The mission behind Makeaway: using technology, land, money, and
        practical skills to escape the rat race and build a more fulfilling life.
      </p>
    </a>
  </section>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--text-muted);
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-main);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .article-grid {
    display: grid;
    gap: 20px;
    margin-top: 72px;
  }

  .article-card,
  .article-card:visited {
    display: block;
    border: 1px solid var(--card-border);
    border-radius: 28px;
    padding: 34px;
    color: var(--text-main);
    text-decoration: none;
    background: var(--card);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .article-card:hover {
    transform: translateY(-6px);
    border-color: rgba(245, 241, 232, 0.45);
    background: var(--card-hover);
    box-shadow: 0 18px 45px rgba(255, 255, 255, 0.06);
  }

  .article-card span {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .article-card h2 {
    margin: 0;
    max-width: 760px;
    color: var(--text-main);
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .article-card p {
    max-width: 720px;
    margin: 20px 0 0;
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  @media (max-width: 760px) {
    .article-card,
    .article-card:visited {
      padding: 26px;
      border-radius: 24px;
    }

    .article-card h2 {
      font-size: clamp(2rem, 12vw, 3.3rem);
    }
  }
</style>