    font-size: clamp(2.4rem, 6vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .intro {
    font-size: 1.2rem;
    line-height: 1.8;
    color: rgba(240, 238, 233, 0.86);
  }

  section {
    margin-top: 3rem;
  }

