    font-size: clamp(1.7rem, 4vw, 2.6rem);
    letter-spacing: -0.035em;
  }

  h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #e9e7e5;
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  p {
    color: rgba(245, 241, 232, 0.82);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  ul {
    display: grid;
    gap: 0.7rem;
    margin: 1rem 0 0;
    padding-left: 1.25rem;
  }

  li {
    color: rgba(245, 241, 232, 0.84);
